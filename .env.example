# pgquorum -- connection environment template.
# Copy to .env (git-ignored) and fill in. Real values live in docker secrets;
# the deploy scripts write the dev values to secrets/dev-credentials.env.

# === Application access (via PgBouncer, pooled) ===
APP_USER=app
APP_PASSWORD=
APP_DB_WRITE=appdb
APP_DB_READ=appdb_ro

# Endpoints published on localhost by Docker Desktop
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432
HAPROXY_WRITE_PORT=5000
HAPROXY_READ_PORT=5001
PATRONI_API_PORT=8008

# Ready-to-use libpq vars (write path: app -> PgBouncer -> HAProxy -> leader)
PGHOST=localhost
PGPORT=6432
PGUSER=app
PGPASSWORD=
PGDATABASE=appdb

# === PostgreSQL internal roles ===
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=
PG_REPLICATION_USER=replicator
PG_REPLICATION_PASSWORD=
PGBOUNCER_AUTH_USER=pgbouncer
PGBOUNCER_AUTH_PASSWORD=
MONITORING_USER=monitoring
MONITORING_PASSWORD=

# === Observability UIs ===
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_ADMIN_PASSWORD=
PROMETHEUS_URL=http://localhost:9090
ALERTMANAGER_URL=http://localhost:9093
HAPROXY_STATS_URL=http://localhost:8404
