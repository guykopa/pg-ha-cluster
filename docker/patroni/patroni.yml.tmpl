# pgquorum -- Patroni configuration template.
# Rendered by entrypoint.sh (envsubst) at container start. Per-node values
# (${PATRONI_NAME}) and secrets (${..._PASSWORD}) are injected from the
# service environment and from Swarm secret files.

scope: ${PATRONI_SCOPE}
namespace: /service/
name: ${PATRONI_NAME}

# REST API consumed by Patroni itself, by HAProxy health-checks (Phase 2)
# and by pgctl. connect_address uses the stable Swarm service DNS name.
restapi:
  listen: 0.0.0.0:8008
  connect_address: ${PATRONI_NAME}:8008

# Distributed Configuration Store: the 3-member etcd cluster.
etcd3:
  hosts: etcd1:2379,etcd2:2379,etcd3:2379

# Bootstrap settings are written to the DCS once, by the first node that
# initialises the cluster; they then govern every member.
bootstrap:
  dcs:
    ttl: 30                     # leader lease; expiry triggers a new election
    loop_wait: 10               # Patroni main loop interval
    retry_timeout: 10           # DCS/PostgreSQL operation retry budget
    maximum_lag_on_failover: 1048576   # max bytes of lag a candidate may have
    postgresql:
      use_pg_rewind: true       # cheaply re-sync a demoted ex-leader
      use_slots: true           # replication slots: avoid WAL loss on outages
      parameters:
        wal_level: replica
        hot_standby: "on"
        max_wal_senders: 10
        max_replication_slots: 10
        wal_keep_size: 128MB
  initdb:
    - encoding: UTF8
    - data-checksums
  pg_hba:
    - local all all trust
    - host replication replicator all scram-sha-256
    - host all all all scram-sha-256

postgresql:
  listen: 0.0.0.0:5432
  connect_address: ${PATRONI_NAME}:5432
  data_dir: /var/lib/postgresql/data/pgdata
  bin_dir: /usr/lib/postgresql/16/bin
  authentication:
    superuser:
      username: postgres
      password: ${PATRONI_SUPERUSER_PASSWORD}
    replication:
      username: replicator
      password: ${PATRONI_REPLICATION_PASSWORD}
  parameters:
    password_encryption: scram-sha-256
    unix_socket_directories: /var/run/postgresql

# No hardware watchdog inside containers; disabled for the dev environment.
# On a real host, a watchdog hardens split-brain protection.
watchdog:
  mode: off

tags:
  nofailover: false
  noloadbalance: false
  clonefrom: false
  nosync: false
