{
  "uid": "pgquorum-overview",
  "title": "pgquorum — Cluster Overview",
  "tags": ["pgquorum"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Leader (patroni_primary)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "max": 1, "min": 0 }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "patroni_primary", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PostgreSQL running (patroni_postgres_running)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "max": 1, "min": 0 }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "patroni_postgres_running", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Replicas",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(patroni_replica == 1)", "instant": true }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HAProxy active servers per backend",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "haproxy_backend_active_servers", "legendFormat": "{{proxy}}" }
      ]
    }
  ]
}
